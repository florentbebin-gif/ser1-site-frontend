{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vite/client", "vitest/globals", "@playwright/test"],
    "noEmit": true,
    "noUncheckedIndexedAccess": false
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "src/vite-env.d.ts",
    "tests/e2e/**/*.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
