{
  "name": "ser1-simple",
  "version": "1.1.0",
  "type": "module",
  "packageManager": "npm@11.12.0",
  "engines": {
    "node": ">=22.22.1 <23",
    "npm": ">=11.12.0 <12"
  },
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:repo": "eslint src tests/e2e api \"scripts/**/*.mjs\" \"*.config.ts\" \"*.cjs\" .storybook --ext .js,.jsx,.ts,.tsx,.mjs,.cjs --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:deno": "cd supabase/functions/admin && deno test lib/auth_test.ts lib/loaders_test.ts cors_test.ts --allow-net --allow-env --deny-import=esm.sh:443,raw.esm.sh:443 --frozen=true",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "coverage": "vitest run --coverage",
    "check:raw-fiscal-usage": "node scripts/check-raw-fiscal-usage.mjs",
    "check:fiscal-hardcode": "node scripts/check-no-hardcoded-fiscal-values.mjs",
    "check:css-colors": "node scripts/check-no-hardcoded-css-theme-colors.mjs",
    "check:theme-sync": "node scripts/check-theme-sync.mjs",
    "check:settings-rls": "node scripts/check-settings-rls-policies.mjs",
    "check:no-js": "node scripts/check-no-js.mjs",
    "check:no-office-artifacts": "node scripts/check-no-office-artifacts.mjs",
    "check:no-console": "node scripts/check-no-console.mjs",
    "check:css-structure": "node scripts/check-css-structure.mjs",
    "check": "npm run lint && npm run lint:css && npm run check:raw-fiscal-usage && npm run check:fiscal-hardcode && npm run check:css-colors && npm run check:theme-sync && npm run check:settings-rls && npm run check:no-js && npm run check:no-office-artifacts && npm run check:no-console && npm run check:css-structure && npm run check:arch && npm run check:circular && npm run check:unused && npm run typecheck && npm test && npm run build",
    "check:arch": "depcruise src --config .dependency-cruiser.cjs --output-type err",
    "check:circular": "depcruise src --config .dependency-cruiser.circular.cjs --output-type err",
    "check:unused": "npx depcheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:base-contrat-dmtg": "node scripts/audit-base-contrat-dmtg.mjs",
    "generate:mortality": "python tools/scripts/generate-mortality-data.py",
    "report:large-files": "node scripts/report-large-files.mjs",
    "analyze": "npx vite-bundle-visualizer",
    "analyze:ci": "vite-bundle-visualizer --template treemap --output dist/bundle-stats.html --open false",
    "check:pre-merge": "pwsh -NoProfile -File scripts/pre-merge-check.ps1",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "lhci": "lhci autorun",
    "docs:engine": "typedoc --options typedoc.json",
    "release:please": "release-please release-pr",
    "icons:build": "node tools/scripts/normalize-business-icons.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.106.0",
    "jszip": "^3.10.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.6",
    "depcheck": "^1.4.7",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "release-please": "^17.6.0",
    "storybook": "^10.4.0",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "supabase": "^2.100.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,json,yml,yaml,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "glob": "13.0.1"
  }
}
