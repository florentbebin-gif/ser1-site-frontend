{
  "name": "ser1-simple",
  "version": "1.1.0",
  "type": "module",
  "packageManager": "npm@11.12.0",
  "engines": {
    "node": ">=22.22.1 <23",
    "npm": ">=10.9.7 <12"
  },
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:repo": "eslint src tests/e2e api \"scripts/**/*.mjs\" \"*.config.ts\" \"*.cjs\" .storybook --ext .js,.jsx,.ts,.tsx,.mjs,.cjs --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:deno": "cd supabase/functions/admin && deno test lib/auth_test.ts lib/loaders_test.ts actions/users_test.ts actions/issues_test.ts actions/themes_test.ts cors_test.ts --allow-net --allow-env --deny-import=esm.sh:443,raw.esm.sh:443 --frozen=true",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "coverage": "vitest run --coverage",
    "check:raw-fiscal-usage": "node scripts/check-raw-fiscal-usage.mjs",
    "check:fiscal-hardcode": "node scripts/check-no-hardcoded-fiscal-values.mjs",
    "check:no-raw-number-input": "node scripts/check-no-raw-number-input.mjs",
    "check:svg-icons": "node scripts/check-svg-icons.mjs",
    "check:sim-cards": "node scripts/check-sim-cards.mjs",
    "check:sim-kpi-border": "node scripts/check-sim-kpi-border.mjs",
    "check:css-colors": "node scripts/check-no-hardcoded-css-theme-colors.mjs",
    "check:theme-sync": "node scripts/check-theme-sync.mjs",
    "check:settings-rls": "node scripts/check-settings-rls-policies.mjs",
    "check:supabase-rls": "node scripts/check-supabase-rls-policies.mjs",
    "check:storage-policies": "node scripts/check-storage-policies.mjs",
    "check:supabase-migrations": "node scripts/check-supabase-migrations.mjs",
    "check:export-parity": "vitest run src/features/placement/__tests__/placementExportParity.test.ts src/pptx/presets/perTransfertDeckBuilder.test.ts src/engine/per/transfert/__tests__/rentProjection.test.ts src/features/tresorerie-societe/__tests__/tresorerieExport.pptx.test.ts src/features/tresorerie-societe/__tests__/tresorerieExport.xlsx.test.ts",
    "check:pptx-images": "node scripts/check-pptx-image-budget.mjs",
    "check:base-cg-migration": "node scripts/check-base-cg-canonical-migration.mjs --check",
    "check:base-cg-schema": "node scripts/check-base-cg-schema.mjs",
    "check:orphan-source-files": "node scripts/check-orphan-source-files.mjs",
    "check:large-files-baseline": "node scripts/check-large-files-baseline.mjs",
    "check:routes-doc-sync": "node scripts/check-routes-doc-sync.mjs",
    "check:naming-conventions": "node scripts/check-naming-conventions.mjs",
    "check:tresorerie-v6-runtime": "node scripts/check-tresorerie-v6-runtime.mjs",
    "check:no-js": "node scripts/check-no-js.mjs",
    "check:no-office-artifacts": "node scripts/check-no-office-artifacts.mjs",
    "check:no-console": "node scripts/check-no-console.mjs",
    "check:ser1-colors-plugin": "node --test tools/eslint-plugin-ser1-colors/ser1Colors.test.mjs",
    "check:css-structure": "node scripts/check-css-structure.mjs",
    "check:deep-imports": "node scripts/check-deep-relative-imports.mjs",
    "logos:generate": "node scripts/generate-company-logo-manifest.mjs --write",
    "check:company-logos": "node scripts/generate-company-logo-manifest.mjs --check",
    "check": "npm run check:static && npm run check:architecture && npm run check:fiscal && npm run check:supabase && npm run check:exports && npm run check:baselines && npm run check:types && npm run check:tests && npm run check:build",
    "check:static": "npm run format:check && npm run lint && npm run lint:css && npm run check:no-raw-number-input && npm run check:svg-icons && npm run check:sim-cards && npm run check:sim-kpi-border && npm run check:css-colors && npm run check:ser1-colors-plugin && npm run check:theme-sync && npm run check:no-js && npm run check:no-office-artifacts && npm run check:no-console && npm run check:css-structure && npm run check:company-logos && npm run check:routes-doc-sync && npm run check:naming-conventions && npm run check:tresorerie-v6-runtime && npm run check:unused",
    "check:architecture": "npm run check:deep-imports && npm run check:orphan-source-files && npm run check:arch && npm run check:circular",
    "check:fiscal": "npm run check:raw-fiscal-usage && npm run check:fiscal-hardcode",
    "check:supabase": "npm run check:base-cg-migration && npm run check:base-cg-schema && npm run check:supabase-rls && npm run check:settings-rls && npm run check:storage-policies && npm run check:supabase-migrations",
    "check:exports": "npm run check:export-parity && npm run check:pptx-images",
    "check:baselines": "npm run check:large-files-baseline",
    "check:types": "npm run typecheck",
    "check:tests": "npm test",
    "check:build": "npm run build",
    "check:arch": "depcruise src --config .dependency-cruiser.cjs --output-type err",
    "check:circular": "depcruise src --config .dependency-cruiser.circular.cjs --output-type err",
    "check:unused": "npx depcheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:base-contrat-dmtg": "node scripts/audit-base-contrat-dmtg.mjs",
    "audit:css-usage": "node scripts/audit-css-usage.mjs",
    "audit:unicode": "node scripts/scan-unicode.mjs",
    "generate:mortality": "python tools/scripts/generate-mortality-data.py",
    "report:large-files": "node scripts/report-large-files.mjs",
    "snapshot:sim": "node scripts/sim-visual-snapshot.mjs",
    "analyze": "npx vite-bundle-visualizer",
    "analyze:ci": "vite-bundle-visualizer --template treemap --output dist/bundle-stats.html --open false",
    "check:pre-merge": "pwsh -NoProfile -File scripts/pre-merge-check.ps1",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "lhci": "lhci autorun",
    "docs:engine": "typedoc --options typedoc.json",
    "release:please": "release-please release-pr",
    "icons:build": "node tools/scripts/normalize-business-icons.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:functional": "npx playwright test --project=chromium",
    "test:e2e:visual": "npx playwright test --project=visual",
    "test:e2e:smoke": "npx playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.106.0",
    "jszip": "^3.10.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.6",
    "depcheck": "^1.4.7",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "release-please": "^17.6.0",
    "storybook": "^10.4.0",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "supabase": "^2.100.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,json,yml,yaml,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "glob": "13.0.1"
  }
}
