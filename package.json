{
  "name": "ser1-simple",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:repo": "eslint src tests/e2e \"scripts/**/*.mjs\" \"*.config.ts\" \"*.cjs\" .storybook --ext .js,.jsx,.ts,.tsx,.mjs,.cjs --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:deno": "deno test supabase/functions/admin/lib/auth_test.ts supabase/functions/admin/lib/loaders_test.ts supabase/functions/admin/cors_test.ts --allow-net --allow-env --deny-import=esm.sh:443,raw.esm.sh:443 --frozen=true",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "coverage": "vitest run --coverage",
    "check:fiscal-hardcode": "node scripts/check-no-hardcoded-fiscal-values.mjs",
    "check:css-colors": "node scripts/check-no-hardcoded-css-theme-colors.mjs",
    "check:theme-sync": "node scripts/check-theme-sync.mjs",
    "check:settings-rls": "node scripts/check-settings-rls-policies.mjs",
    "check:no-js": "node -e \"const fs=require('fs'),path=require('path');function f(d){return fs.readdirSync(d).flatMap(e=>{const p=path.join(d,e);return fs.statSync(p).isDirectory()?f(p):[p]})}const r=f('src').filter(p=>/\\.(js|jsx)$/.test(p));if(r.length){console.error('Plain .js/.jsx files found in src/ (use .ts/.tsx):');r.forEach(p=>console.error(' ',p));process.exit(1)}else console.log('check:no-js ✅')\"",
    "check:no-console": "node scripts/check-no-console.mjs",
    "check:css-structure": "node scripts/check-css-structure.mjs",
    "check": "npm run lint && npm run lint:css && npm run check:fiscal-hardcode && npm run check:css-colors && npm run check:theme-sync && npm run check:settings-rls && npm run check:no-js && npm run check:no-console && npm run check:css-structure && npm run check:arch && npm run check:circular && npm run check:unused && npm run typecheck && npm test && npm run build",
    "check:arch": "depcruise src --config .dependency-cruiser.cjs --output-type err",
    "check:circular": "npx madge --circular --ts-config tsconfig.json --extensions ts,tsx,js,jsx src/",
    "check:unused": "npx depcheck",
    "audit:base-contrat-dmtg": "node scripts/audit-base-contrat-dmtg.mjs",
    "report:large-files": "node scripts/report-large-files.mjs",
    "analyze": "npx vite-bundle-visualizer",
    "check:pre-merge": "pwsh -NoProfile -File scripts/pre-merge-check.ps1",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "lhci": "lhci autorun",
    "docs:engine": "typedoc --options typedoc.json",
    "release:please": "release-please release-pr",
    "icons:build": "node tools/scripts/normalize-business-icons.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.42.0",
    "jszip": "^3.10.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.39.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitest/coverage-v8": "^4.1.6",
    "depcheck": "^1.4.7",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "release-please": "^17.6.0",
    "storybook": "^10.4.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "supabase": "2.74.5",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vite": "^5.2.0",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "glob": "13.0.1"
  }
}
